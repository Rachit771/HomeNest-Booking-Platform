<%- include('../partials/head') %>
</head>
<body class="bg-gray-100">
  <%- include('../partials/nav') %>

  <main class="container mx-auto mt-10 max-w-6xl p-6">
    <h2 class="text-3xl font-bold text-red-500 text-center mb-8">
      My Bookings
    </h2>

    <% if (bookings.length === 0) { %>
      <p class="text-center text-gray-500">No bookings yet.</p>
    <% } %>

    <div class="grid md:grid-cols-2 gap-6">

      <% bookings.forEach(booking => { %>
        <div class="bg-white rounded-xl shadow-md p-5">

          <!-- Home Info -->
          <img 
            src="<%= booking.homeId.photoUrl %>" 
            class="w-full h-48 object-cover rounded-lg mb-4"
          />

          <h3 class="text-xl font-semibold">
            <%= booking.homeId.houseName %>
          </h3>

          <p class="text-gray-600 mb-2">
            <%= booking.homeId.location %>
          </p>

          <p class="text-sm text-gray-500">
            <strong>From:</strong> <%= booking.startDate.toDateString() %>
          </p>
          <p class="text-sm text-gray-500 mb-4">
            <strong>To:</strong> <%= booking.endDate.toDateString() %>
          </p>

          <!-- STATUS LOGIC -->

          <% if (booking.status === "PAYMENT_PENDING") { %>
            
            <div class="flex gap-3">

              <!-- Confirm -->
              <a 
  href="/Book/payment/<%= booking._id %>" 
  class="flex-1 text-center bg-green-500 hover:bg-green-600 text-white py-2 rounded font-semibold"
>
  Confirm & Pay
</a>


              <!-- Cancel -->
              <form action="/Book/cancel/<%= booking._id %>?_method=PATCH" 
  method="POST" class="flex-1">
                <button class="w-full bg-red-500 hover:bg-red-600 text-white py-2 rounded font-semibold">
                  Cancel
                </button>
              </form>

            </div>

          <% } else if (booking.status === "CONFIRMED") { %>

            <span class="inline-block bg-green-100 text-green-700 px-4 py-2 rounded font-semibold">
              ✅ Confirmed
            </span>

          <% } else if (booking.status === "CANCELLED") { %>

            <span class="inline-block bg-red-100 text-red-700 px-4 py-2 rounded font-semibold">
              ❌ Cancelled
            </span>

          <% } %>

        </div>
      <% }) %>

    </div>
  </main>
</body>
</html>
